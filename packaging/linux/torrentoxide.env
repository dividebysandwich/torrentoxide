# TorrentOxide configuration (systemd EnvironmentFile).
# Uncomment values as needed, then: sudo systemctl restart torrentoxide

# --- Authentication (set BOTH to require login) ---
#AUTH_USERNAME=admin
#AUTH_PASSWORD=change-me
# Signs the session cookie — set a long random value when auth is enabled:
#SESSION_SECRET=

# --- Overrides (defaults are set in the unit file) ---
#LEPTOS_SITE_ADDR=0.0.0.0:3000
#DOWNLOAD_DIR=/var/lib/torrentoxide/downloads
#BROWSE_ROOT=/var/lib/torrentoxide/downloads
#RUST_LOG=info,librqbit=warn
