# ---- TorrentOxide configuration -------------------------------------------
# Copy to `.env` and adjust. All values are optional; sensible defaults apply.

# Default folder new torrents download into.
DOWNLOAD_DIR=./downloads

# Root the remote directory browser is confined to (defaults to DOWNLOAD_DIR).
# Browsing and saving are restricted to this subtree.
BROWSE_ROOT=./downloads

# Where librqbit stores session state so torrents resume across restarts.
PERSISTENCE_DIR=./.rqbit-session

# Address the server binds to. This maps to Leptos' LEPTOS_SITE_ADDR;
# under `cargo leptos` it is taken from Cargo.toml [package.metadata.leptos].
LEPTOS_SITE_ADDR=127.0.0.1:3000

# ---- Authentication (optional) --------------------------------------------
# Auth is ENABLED only when BOTH username and password are set.
# Leave blank for no authentication.
AUTH_USERNAME=
AUTH_PASSWORD=

# Secret used to sign session cookies. Set a long random value in production.
# If unset, an ephemeral key is generated (sessions reset on restart).
SESSION_SECRET=

# ---- PVR / metadata (optional) --------------------------------------------
# TMDb API key, used by the media library, "wanted" list and episode monitor
# to identify movies/shows and look up episode air dates.
# Get a free key at https://www.themoviedb.org/settings/api
# Can also be set in the web UI (Settings → Providers); the UI value wins.
TMDB_API_KEY=

# ---- Logging (optional) ---------------------------------------------------
# RUST_LOG=info,librqbit=info
